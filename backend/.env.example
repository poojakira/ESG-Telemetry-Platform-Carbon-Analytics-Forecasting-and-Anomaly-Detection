# EcoTrack Enterprise Configuration Template
# Duplicate this file to .env and populate with production secrets

# --- 1. System Identity ---
APP_NAME=EcoTrack-Enterprise
VERSION=7.0.0_ABSOLUTE_REALITY
ENVIRONMENT=production

# --- 2. API Configuration ---
API_HOST=127.0.0.1
API_PORT=8000
DEBUG=False

# --- 3. Data Infrastructure ---
# Absolute paths are recommended for production stability
DATA_PATH=./backend/data/dpp_data.csv
DB_PATH=./backend/data/sustainability.db

# --- 4. AI Inference Engine ---
MODEL_PATH=./backend/data/model.pkl
SECURITY_PATH=./backend/data/security_model.pkl

# --- 5. Security Guardrails ---
SECRET_KEY=generate_a_secure_random_key_here
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000
